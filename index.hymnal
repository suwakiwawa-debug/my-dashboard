<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>智能家居儀表板 - 實時生產版</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    @keyframes ticker {
      0% { transform: translate3d(0, 0, 0); }
      100% { transform: translate3d(-50%, 0, 0); }
    }
    .ticker-track {
      display: inline-block;
      white-space: nowrap;
      animation: ticker 45s linear infinite;
    }
    .pixel-font {
      font-family: 'Courier New', Courier, monospace;
      font-weight: bold;
    }
  </style>
</head>
<body class="bg-black text-white min-h-screen flex flex-col justify-between overflow-hidden select-none">

  <div class="p-6 flex-1 grid grid-cols-1 md:grid-cols-2 gap-6 pb-20">
    
    <div class="bg-blue-900/40 border-2 border-blue-500 rounded-xl p-6 flex flex-col justify-between shadow-lg shadow-blue-500/20">
      <div>
        <div class="text-blue-400 text-xs font-bold tracking-wider mb-2">HKO REAL-TIME SYSTEM</div>
        <div id="current-time" class="text-5xl md:text-6xl font-black text-cyan-300 pixel-font">--:-- --</div>
        <div id="current-date" class="text-sm text-gray-400 mt-1">----/--/-- ---</div>
      </div>

      <div class="mt-4 space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-gray-300 text-lg">溫度 Temp:</span>
          <span id="weather-temp" class="text-4xl font-bold text-white pixel-font">-- °C</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-gray-300 text-lg">濕度 Humidity:</span>
          <span id="weather-humidity" class="text-3xl font-bold text-cyan-400 pixel-font">-- %</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-gray-300 text-lg">紫外線 UV Index:</span>
          <span id="weather-uv" class="text-2xl font-bold text-yellow-400 pixel-font">--</span>
        </div>
        <div class="flex items-center justify-between border-t border-blue-500/20 pt-2">
          <span class="text-gray-300 text-lg">定點降雨 Rain:</span>
          <span id="weather-rain" class="text-2xl font-bold text-emerald-400 pixel-font">--</span>
        </div>
        <div class="border-t border-blue-500/30 pt-2 text-xs text-blue-300" id="weather-warning">
          警告: 正常天氣 Alert: Normal Weather
        </div>
      </div>
    </div>

    <div class="bg-zinc-900 border-2 border-zinc-700 rounded-xl p-6 flex flex-col shadow-lg">
      <div class="text-orange-400 text-xs font-bold tracking-wider mb-4">HK BUS STATION HUB</div>
      
      <div class="flex-1 flex flex-col justify-around space-y-4">
        <div class="flex items-center justify-between border-b border-zinc-800 pb-3">
          <div>
            <span class="bg-red-600 text-white font-bold px-2 py-1 rounded text-lg pixel-font">619</span>
            <span class="text-xs text-gray-400 block mt-1">往 中環 (港澳碼頭)</span>
          </div>
          <div class="text-right">
            <span class="text-2xl font-bold text-green-400 pixel-font" id="bus-1-eta">連線中...</span>
          </div>
        </div>

        <div class="flex items-center justify-between border-b border-zinc-800 pb-3">
          <div>
            <span class="bg-red-600 text-white font-bold px-2 py-1 rounded text-lg pixel-font">40A</span>
            <span class="text-xs text-gray-400 block mt-1">往 葵興站</span>
          </div>
          <div class="text-right">
            <span class="text-2xl font-bold text-green-400 pixel-font" id="bus-2-eta">連線中...</span>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="bg-zinc-950 border-t-2 border-amber-400 fixed bottom-0 left-0 w-full py-3 overflow-hidden shadow-2xl z-50">
    <div class="relative w-full flex items-center">
      <span class="absolute left-0 bg-amber-400 text-black font-black px-3 py-1 text-sm z-10 shadow-md">最新消息</span>
      <div class="ticker-track pl-[90px] text-base text-gray-100 font-medium" id="news-ticker">
        正在載入官方實時新聞摘要... 請稍候...
      </div>
    </div>
  </div>

  <script>
    // 1. 實時時間功能
    function updateClock() {
      const now = new Date();
      const optionsDate = { year: 'numeric', month: '2-digit', day: '2-digit', weekday: 'short' };
      let hours = now.getHours();
      const
